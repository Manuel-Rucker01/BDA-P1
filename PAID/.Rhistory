!is.na(utm_coordinate_x) & !is.na(utm_coordinate_y), # Drop blank coordinates
utm_coordinate_x > 400000,                           # Keep only valid X range for BCN
utm_coordinate_y > 4500000                           # Keep only valid Y range for BCN
)
# 2. Re-create the sf object with the clean data
accidents_sf <- st_as_sf(accidents_clean,
coords = c("utm_coordinate_x", "utm_coordinate_y"),
crs = 25831)
# 3. Plot it again!
ggplot() +
geom_sf(data = accidents_sf, color = "red", size = 0.5, alpha = 0.1) +
theme_minimal() +
ggtitle("Cleaned Map of Barcelona Traffic Accidents")
View(accidents_sf)
View(accidents)
