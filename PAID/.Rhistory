library(dplyr)
library(readr)
# 2. Load the datasets
# Adjust the file paths and the delimiter (sep/delim) for the radars file as needed
accidents  <- read_csv("accidents_opendata.csv")
radars     <- read.table("radars.txt", header = TRUE, skip = 2, dec = ",", sep = "", fill = TRUE)        # Ensures rows with different lengths don't error
accidents <- accidents %>%
drop_na(utm_coordinate_x, utm_coordinate_y)
accidents <- accidents %>%
filter(!is.na(longitude) & !is.na(latitude))
radars <- radars %>%
drop_na(X, Y)
# --- IMPORTANT: Check your column names ---
# Replace "UTM_X_Accident" / "UTM_Y_Accident" and "UTM_X_Radar" / "UTM_Y_Radar"
# with the actual names of the coordinate columns in your datasets.
# 3. Convert standard dataframes to Spatial Objects (sf)
# EPSG:25831 is the CRS code for ETRS89 UTM Zone 31N
accidents_sf <- st_as_sf(accidents,
coords = c("utm_coordinate_x", "utm_coordinate_y"),
crs = 25831)
radars_sf <- st_as_sf(radars,
coords = c("X", "Y"),
crs = 25831)
library(sf)
library(leaflet)
# Leaflet needs lon/lat
acc_ll <- st_transform(accidents_sf, 4326)
rad_ll <- st_transform(radars_sf, 4326)
# 1) Accidents map
accidents_map <- leaflet(acc_ll) %>%
addProviderTiles(providers$CartoDB.Positron) %>%
addCircleMarkers(
radius = 2, stroke = FALSE, fillOpacity = 0.25
) %>%
addLegend(position = "bottomright",
colors = "gray40", labels = "Accidents", title = "Layer")
# 2) Radars map
radars_map <- leaflet(rad_ll) %>%
addProviderTiles(providers$CartoDB.Positron) %>%
addCircleMarkers(
radius = 5, color = "red", fillOpacity = 0.9
) %>%
addLegend(position = "bottomright",
colors = "red", labels = "Radars", title = "Layer")
accidents_map
