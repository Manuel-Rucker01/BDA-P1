radars_sf <- st_as_sf(radars,
coords = c("X", "Y"),
crs = 25831)
# 4. Perform the Spatial Join (Nearest Feature)
# This attaches the attributes of the nearest radar to each accident
accidents_with_radars <- st_join(accidents_sf, radars_sf, join = st_nearest_feature)
# 5. Calculate the exact distance to that nearest radar
# Find the indices of the nearest radars
nearest_indices <- st_nearest_feature(accidents_sf, radars_sf)
# Extract those specific radars
nearest_radars <- radars_sf[nearest_indices, ]
# Calculate distance in meters (st_distance returns a matrix, by_element makes it a vector)
accidents_with_radars$distance_to_radar_m <- st_distance(accidents_sf,
nearest_radars,
by_element = TRUE)
# Convert the distance from an 'units' object to a simple numeric column
accidents_with_radars$distance_to_radar_m <- as.numeric(accidents_with_radars$distance_to_radar_m)
# 6. Create feature engineering columns for your IDSS
accidents_with_radars <- accidents_with_radars %>%
mutate(
# Boolean: Did the accident happen within 500 meters of a radar?
within_500m_radar = ifelse(distance_to_radar_m <= 500, TRUE, FALSE)
)
# 7. Export the final dataset
# Drop the spatial geometry column so you can use it in standard ML/IDSS models
final_dataframe <- st_drop_geometry(accidents_with_radars)
# Save to CSV
write_csv(final_dataframe, "integrated_idss_dataset.csv")
print("Data successfully integrated and saved!")
View(final_dataframe)
