# Load necessary libraries
library(tidyverse)
library(sf)
# 1. LOAD DATASETS
# Ensure these files are in your working directory
accidents_raw  <- read_csv("accidents_opendata.csv")
radars_raw     <- read.table("radars.txt", header = TRUE, skip = 2, dec = ",", sep = "", fill = TRUE)        # Ensures rows with different lengths don't error
aforaments_raw <- read_csv("2025_aforament_descripcio.csv")
# 2. PREPROCESS ACCIDENTS
# Accidents usually come in WGS84 (Lon/Lat). We convert them to UTM 31N (meters).
accidents <- accidents_raw %>%
filter(!is.na(longitude) & !is.na(latitude)) %>%
st_as_sf(coords = c("longitude", "latitude"), crs = 4326) %>%
st_transform(25831) # Convert to UTM 31N
# 3. PREPROCESS RADARS (Based on your image)
# The image shows columns 'X' and 'Y' in ETRS89 format.
radars <- radars_raw %>%
filter(!is.na(X) & !is.na(Y)) %>%
# We use CRS 25831 because those large numbers are UTM coordinates
st_as_sf(coords = c("X", "Y"), crs = 25831)
# 4. PREPROCESS TRAFFIC STATIONS (Aforaments)
aforaments <- aforaments_raw %>%
filter(!is.na(X_ETRS89) & !is.na(Y_ETRS89)) %>%
st_as_sf(coords = c("X_ETRS89", "Y_ETRS89"), crs = 25831)
# 5. SPATIAL CALCULATIONS
# Calculate distance from each accident to the nearest radar
dist_radars <- st_distance(accidents, radars)
accidents$dist_to_radar_m <- apply(dist_radars, 1, min)
# Calculate distance from each accident to the nearest traffic station
dist_traffic <- st_distance(accidents, aforaments)
accidents$nearest_station_idx <- apply(dist_traffic, 1, which.min)
accidents$dist_to_station_m  <- apply(dist_traffic, 1, min)
# Link the Traffic Station ID to the accident
accidents$nearest_station_id <- aforaments$ID_ESTACIO[accidents$nearest_station_idx]
# 6. FEATURE ENGINEERING
accidents <- accidents %>%
mutate(
# A 'Safety Gap' exists if an accident is far from a radar (> 1km)
safety_gap = if_else(dist_to_radar_m > 1000, 1, 0),
# Check if the traffic station is close enough to be relevant
relevant_traffic = if_else(dist_to_station_m <= 1000, 1, 0)
)
# 7. CLEAN UP AND EXPORT
# We convert back to a regular dataframe for your IDSS model
final_dataset <- accidents %>%
# Keep coordinates in Lon/Lat for easy plotting later
bind_cols(st_coordinates(st_transform(., 4326))) %>%
rename(lon = X, lat = Y) %>%
as.data.frame() %>%
select(
case_id, district_name, neighborhood_name,
lon, lat,
n_victims, n_vehicles,
dist_to_radar_m, safety_gap,
nearest_station_idx, dist_to_station_m, relevant_traffic
)
write_csv(final_dataset, "barcelona_idss_master_dataset.csv")
print("Merging complete! Your master dataset is ready.")
View(final_dataset)
View(accidents)
