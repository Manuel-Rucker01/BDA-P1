# Load dataset
data <- read_csv("2025_accidents_causa_conductor_gu_bcn.csv")
# 1. Print the number of rows
cat("--- NUMBER OF ROWS ---\n")
# 1. Print the number of rows
cat("--- NUMBER OF ROWS ---\n")
# 1. Print the number of rows
cat("--- NUMBER OF ROWS ---\n")
# 1. Print the number of rows
cat("--- NUMBER OF ROWS ---\n")
cat("Total rows:", nrow(data), "\n\n")
# 2. Show all variables
cat("--- ALL VARIABLES ---\n")
print(names(data))
cat("\n")
# 3. Range of numeric variables
cat("--- RANGE OF NUMERIC VARIABLES ---\n")
# Find which columns are numeric
num_cols <- sapply(data, is.numeric)
if (any(num_cols)) {
for (col_name in names(data)[num_cols]) {
# Calculate range, ignoring NAs so it doesn't break
col_range <- range(data[[col_name]], na.rm = TRUE)
cat(sprintf("%s: [%s, %s]\n", col_name, col_range[1], col_range[2]))
}
} else {
cat("No numeric variables found in this dataset.\n")
}
cat("\n")
# 4. Modalities of categorical variables
cat("--- MODALITIES OF CATEGORICAL VARIABLES ---\n")
# Find which columns are categorical (characters, factors, or logicals)
cat_cols <- sapply(data, function(x) is.character(x) | is.factor(x) | is.logical(x))
if (any(cat_cols)) {
for (col_name in names(data)[cat_cols]) {
# Get unique values, ignoring NAs for a cleaner list
modalities <- unique(na.omit(data[[col_name]]))
cat(sprintf("%s: %s\n", col_name, paste(modalities, collapse = ", ")))
}
} else {
cat("No categorical variables found in this dataset.\n")
}
View(data)
